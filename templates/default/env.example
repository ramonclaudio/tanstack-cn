# Copy to .env for local dev. Client-exposed vars must be prefixed VITE_
# (available via import.meta.env). Server-only vars go bare (process.env in
# server functions).

# Canonical URL for SEO meta (canonical, og:url, sitemap entries).
# src/lib/site.ts reads this with a hardcoded fallback. For production,
# either edit the fallback in src/lib/site.ts or set this in your deploy
# platform's env vars (Vercel/Netlify/Cloudflare dashboard) so the meta
# points at your real domain.
VITE_SITE_URL=https://tanstack-cn.vercel.app
